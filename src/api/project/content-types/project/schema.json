{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "body": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "publishDate": {
      "type": "datetime",
      "required": true
    },
    "technologies": {
      "type": "json"
    },
    "tags": {
      "type": "json"
    },
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "imageProjectPrefix": {
      "type": "string"
    },
    "showInAbout": {
      "type": "boolean",
      "default": true
    }
  }
}
